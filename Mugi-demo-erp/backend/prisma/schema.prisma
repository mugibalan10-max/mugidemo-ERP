generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  roleId    Int?     @map("role_id")
  role      Role?    @relation(fields: [roleId], references: [id])
  hourlyRate Decimal @default(0) @map("hourly_rate") @db.Decimal(10, 2)
  createdAt DateTime @default(now())
  
  assignedTasks Task[]   @relation("TaskAssignee")
  reportedTasks Task[]   @relation("TaskReporter")
  workLogs      WorkLog[]
  taskComments  TaskComment[]
  taskLogs      TaskLog[]

  @@map("users")
}

model Role {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  users       User[]
  permissions PermissionAssignment[]

  @@map("roles")
}

model Permission {
  id          Int      @id @default(autoincrement())
  moduleName  String   @map("module_name")
  action      String   // e.g., create, view, edit, delete, manage
  description String?
  assignments PermissionAssignment[]

  @@unique([moduleName, action])
  @@map("permissions")
}

model PermissionAssignment {
  id           Int        @id @default(autoincrement())
  roleId       Int        @map("role_id")
  permissionId Int        @map("permission_id")
  role         Role       @relation(fields: [roleId], references: [id])
  permission   Permission @relation(fields: [permissionId], references: [id])

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

model Lead {
  id         Int      @id @default(autoincrement())
  name       String   @db.VarChar(100)
  email      String?  @unique @db.VarChar(100)
  phone      String?  @unique @db.VarChar(20)
  company    String?  @db.VarChar(150)
  source     String?  @default("Manual") @db.VarChar(50) // Manual, Website, WhatsApp, Ads
  status     String   @default("New") @db.VarChar(50) // New, Contacted, Qualified, Proposal, Won, Lost
  score      Int      @default(0)
  tags       Json?    // Array of tags
  assignedTo Int?     @map("assigned_to")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  activities LeadActivity[]
  notes      LeadNote[]
  opportunity Opportunity?

  @@map("leads")
}

model LeadActivity {
  id          Int      @id @default(autoincrement())
  leadId      Int      @map("lead_id")
  type        String   @db.VarChar(50) // Call, Email, Meeting, Note
  description String   @db.Text
  scheduledAt DateTime? @map("scheduled_at")
  completed   Boolean  @default(false)
  createdAt   DateTime @default(now()) @map("created_at")

  lead        Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@map("lead_activities")
}

model LeadNote {
  id        Int      @id @default(autoincrement())
  leadId    Int      @map("lead_id")
  content   String   @db.Text
  createdBy Int?     @map("created_by")
  createdAt DateTime @default(now()) @map("created_at")

  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@map("lead_notes")
}

model Opportunity {
  id                Int      @id @default(autoincrement())
  leadId            Int      @unique @map("lead_id")
  customerId        Int?     @map("customer_id")
  value             Decimal  @db.Decimal(12, 2)
  stage             String   @default("Proposal") @db.VarChar(50)
  expectedCloseDate DateTime? @map("expected_close_date")
  createdAt         DateTime @default(now()) @map("created_at")

  lead              Lead     @relation(fields: [leadId], references: [id])
  customer          Customer? @relation(fields: [customerId], references: [id])

  @@map("opportunities")
}

model Customer {
  id              Int      @id @default(autoincrement())
  name            String   @db.VarChar(150)
  email           String?  @unique @db.VarChar(150)
  phone           String?  @unique @db.VarChar(50)
  companyName     String?  @map("company_name") @db.VarChar(150)
  gstNumber       String?  @map("gst_number") @db.VarChar(50)
  billingAddress  String?  @map("billing_address") @db.Text
  shippingAddress String?  @map("shipping_address") @db.Text
  creditLimit     Decimal  @default(0) @map("credit_limit") @db.Decimal(12, 2)
  paymentTerms    String?  @map("payment_terms") @db.VarChar(100)
  customerType    String   @default("Retail") @map("customer_type") @db.VarChar(50)
  status          String   @default("Active") @db.VarChar(30)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at")

  invoices        Invoice[]
  payments        Payment[]
  opportunities   Opportunity[]
  salesOrders     SalesOrder[]
  ledger          CustomerLedger?
  tickets         SupportTicket[]
  returns         CustomerReturn[]

  @@map("customers")
}

model SalesOrder {
  id              Int      @id @default(autoincrement())
  orderNumber     String   @unique @map("order_number")
  customerId      Int      @map("customer_id")
  orderDate       DateTime @default(now()) @map("order_date")
  status          String   @default("Draft") @db.VarChar(50) // Draft, Confirmed, Delivered, Invoiced
  totalAmount     Decimal  @map("total_amount") @db.Decimal(12, 2)
  isBlocked       Boolean  @default(false) @map("is_blocked")
  approvalStatus  String   @default("Approved") @map("approval_status") @db.VarChar(50)
  createdAt       DateTime @default(now()) @map("created_at")

  customer        Customer @relation(fields: [customerId], references: [id])
  items           SalesOrderItem[]

  @@map("sales_orders")
}

model SalesOrderItem {
  id          Int      @id @default(autoincrement())
  orderId     Int      @map("order_id")
  productId   Int      @map("product_id")
  quantity    Int
  unitPrice   Decimal  @map("unit_price") @db.Decimal(10, 2)
  total       Decimal  @db.Decimal(12, 2)

  order       SalesOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product     Product    @relation(fields: [productId], references: [id])

  @@map("sales_order_items")
}

model CustomerLedger {
  id               Int      @id @default(autoincrement())
  customerId       Int      @unique @map("customer_id")
  outstandingAmount Decimal  @default(0) @map("outstanding_amount") @db.Decimal(12, 2)
  totalBilled      Decimal  @default(0) @map("total_billed") @db.Decimal(12, 2)
  totalPaid        Decimal  @default(0) @map("total_paid") @db.Decimal(12, 2)
  lastUpdated      DateTime @default(now()) @updatedAt @map("last_updated")

  customer         Customer @relation(fields: [customerId], references: [id])

  @@map("customer_ledgers")
}

model SupportTicket {
  id          Int      @id @default(autoincrement())
  customerId  Int      @map("customer_id")
  subject     String   @db.VarChar(200)
  description String   @db.Text
  status      String   @default("Open") @db.VarChar(50) // Open, In Progress, Resolved
  priority    String   @default("Medium") @db.VarChar(20)
  createdAt   DateTime @default(now()) @map("created_at")

  customer    Customer @relation(fields: [customerId], references: [id])

  @@map("support_tickets")
}

model CustomerReturn {
  id          Int      @id @default(autoincrement())
  customerId  Int      @map("customer_id")
  orderId     Int?     @map("order_id")
  reason      String   @db.Text
  amount      Decimal  @db.Decimal(12, 2)
  status      String   @default("Pending") @db.VarChar(50) // Pending, Approved, Refunded
  createdAt   DateTime @default(now()) @map("created_at")

  customer    Customer @relation(fields: [customerId], references: [id])

  @@map("customer_returns")
}

model ActivityLog {
  id        Int      @id @default(autoincrement())
  module    String   @db.VarChar(50)
  action    String   @db.VarChar(50)
  message   String   @db.Text
  oldData   Json?    @map("old_data")
  newData   Json?    @map("new_data")
  ipAddress String?  @map("ip_address") @db.VarChar(45)
  targetId  Int?     @map("target_id")
  userId    Int?     @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("activity_logs")
}

model Invoice {
  id               Int      @id @default(autoincrement())
  invoiceNo        String   @unique @map("invoice_no")
  customerId       Int      @map("customer_id")
  orderId          Int?     @map("order_id")
  subtotal         Decimal  @db.Decimal(12, 2)
  discount         Decimal  @default(0) @db.Decimal(12, 2)
  cgstAmount       Decimal  @default(0) @map("cgst_amount") @db.Decimal(12, 2)
  sgstAmount       Decimal  @default(0) @map("sgst_amount") @db.Decimal(12, 2)
  igstAmount       Decimal  @default(0) @map("igst_amount") @db.Decimal(12, 2)
  total            Decimal  @db.Decimal(12, 2)
  amountPaid       Decimal  @default(0) @map("amount_paid") @db.Decimal(12, 2)
  currency         String   @default("INR") @db.VarChar(10)
  status           String   @default("Draft") @db.VarChar(50) // Draft, Pending Approval, Approved, Partially Paid, Paid, Overdue, Void
  approvalStatus   String   @default("Pending") @map("approval_status") @db.VarChar(50)
  dueDate          DateTime? @map("due_date")
  pdfUrl           String?  @map("pdf_url") @db.Text
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @default(now()) @updatedAt @map("updated_at")

  customer         Customer @relation(fields: [customerId], references: [id])
  items            InvoiceItem[]

  @@map("invoices")
}

model InvoiceItem {
  id         Int     @id @default(autoincrement())
  invoiceId  Int     @map("invoice_id")
  productId  Int     @map("product_id")
  quantity   Int
  unitPrice  Decimal @map("unit_price") @db.Decimal(12, 2)
  discount   Decimal @default(0) @db.Decimal(12, 2)
  taxPercent Decimal @default(18) @map("tax_percent") @db.Decimal(5, 2)
  total      Decimal @db.Decimal(12, 2)

  invoice    Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  product    Product @relation(fields: [productId], references: [id])

  @@map("invoice_items")
}

model Payment {
  id           Int      @id @default(autoincrement())
  invoiceNo    String?  @map("invoice_no") @db.VarChar(50)
  customerId   Int?     @map("customer_id")
  amount       Decimal  @db.Decimal(10, 2)
  status       String   @default("Pending") @db.VarChar(50)
  paymentDate  DateTime @default(now()) @map("payment_date")
  
  // Razorpay Integration Fields
  orderId      String?  @map("order_id") @db.VarChar(100)
  paymentId    String?  @map("payment_id") @db.VarChar(100)
  signature    String?  @db.VarChar(255)
  method       String?  @default("Razorpay") @db.VarChar(50)

  customer     Customer? @relation(fields: [customerId], references: [id])

  @@map("payments")
}

model SyncQueue {
  id            String   @id @default(uuid())
  entityType    String   @map("entity_type") // invoice, payment, stock
  entityId      String   @map("entity_id")
  payload       Json
  status        String   @default("QUEUED") // QUEUED, PROCESSING, SUCCESS, FAILED
  retryCount    Int      @default(0) @map("retry_count")
  maxRetries    Int      @default(5) @map("max_retries")
  nextRetryAt   DateTime? @map("next_retry_at")
  lastError     String?  @map("last_error") @db.Text
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("sync_queue")
}

model Product {
  id              Int      @id @default(autoincrement())
  productName     String   @map("product_name")
  sku             String   @unique
  category        String   @default("General") @db.VarChar(100)
  unitOfMeasure   String   @default("NOS") @map("unit_of_measure") @db.VarChar(20)
  hsnCode         String?  @map("hsn_code") @db.VarChar(50)
  taxPercent      Decimal  @default(18) @map("tax_percent") @db.Decimal(5, 2)
  isBatchTracked  Boolean  @default(false) @map("is_batch_tracked")
  quantity        Int      @default(0) // Total Available
  reservedQty     Int      @default(0) @map("reserved_qty") // SO reserved
  inTransitQty    Int      @default(0) @map("in_transit_qty") 
  damagedQty      Int      @default(0) @map("damaged_qty")
  incomingStock   Int      @default(0) @map("incoming_stock") // PO reserved
  minStock        Int      @default(10) @map("min_stock")
  price           Decimal  @db.Decimal(10, 2) // Moving Average Price / Standard
  createdAt       DateTime @default(now()) @map("created_at")

  purchaseOrderItems PurchaseOrderItem[]
  grnItems           GRNItem[]
  invoiceItems       InvoiceItem[]
  salesOrderItems    SalesOrderItem[]
  stockLedgers       StockLedger[]
  stockTransfers     StockTransferItem[]
  stockAdjustments   StockAdjustment[]

  @@map("products")
}

model Warehouse {
  id           Int      @id @default(autoincrement())
  name         String   @unique @db.VarChar(100)
  location     String?  @db.VarChar(200)
  manager      String?  @db.VarChar(100)
  
  bins         WarehouseBin[]
  ledgers      StockLedger[]
  
  @@map("warehouses")
}

model WarehouseBin {
  id           Int      @id @default(autoincrement())
  warehouseId  Int      @map("warehouse_id")
  binCode      String   @map("bin_code") @db.VarChar(50) // e.g. RACK-A-1
  capacity     Int      @default(0)
  
  warehouse    Warehouse @relation(fields: [warehouseId], references: [id])
  ledgers      StockLedger[]
  
  @@unique([warehouseId, binCode])
  @@map("warehouse_bins")
}

model StockLedger {
  id           Int      @id @default(autoincrement())
  productId    Int      @map("product_id")
  warehouseId  Int      @map("warehouse_id")
  binId        Int?     @map("bin_id")
  batchNumber  String?  @map("batch_number") @db.VarChar(100)
  expiryDate   DateTime? @map("expiry_date")
  quantity     Int      @default(0)
  
  product      Product   @relation(fields: [productId], references: [id])
  warehouse    Warehouse @relation(fields: [warehouseId], references: [id])
  bin          WarehouseBin? @relation(fields: [binId], references: [id])
  
  @@map("stock_ledgers")
}

model StockTransferItem {
  id           Int      @id @default(autoincrement())
  transferNo   String   @map("transfer_no")
  productId    Int      @map("product_id")
  fromWhId     Int      @map("from_wh_id")
  toWhId       Int      @map("to_wh_id")
  quantity     Int
  status       String   @default("In Transit") // In Transit, Completed
  createdAt    DateTime @default(now())
  
  product      Product  @relation(fields: [productId], references: [id])
  
  @@map("stock_transfers")
}

model StockAdjustment {
  id           Int      @id @default(autoincrement())
  productId    Int      @map("product_id")
  warehouseId  Int      @map("warehouse_id")
  adjustmentQty Int     @map("adjustment_qty")
  reason       String   @db.Text
  createdAt    DateTime @default(now())
  
  product      Product  @relation(fields: [productId], references: [id])
  
  @@map("stock_adjustments")
}

model Vendor {
  id          Int      @id @default(autoincrement())
  vendorCode  String   @unique @map("vendor_code")
  vendorName  String   @map("vendor_name") @db.VarChar(100)
  gstNumber   String?  @map("gst_number") @db.VarChar(20)
  phone       String?  @db.VarChar(15)
  email       String?  @db.VarChar(100)
  address     String?  @db.Text
  panNumber   String?  @map("pan_number") @db.VarChar(20)
  bankDetails Json?    @map("bank_details")
  paymentTerms String? @default("Net 30") @map("payment_terms") @db.VarChar(50)
  status      String   @default("Active") @db.VarChar(30)
  createdAt   DateTime @default(now()) @map("created_at")

  purchaseOrders PurchaseOrder[]
  ledger         VendorLedger?
  transactions   VendorTransaction[]
  bills          VendorBill[]
  payments       VendorPayment[]

  @@map("vendors")
}

model VendorLedger {
  id               Int      @id @default(autoincrement())
  vendorId         Int      @unique @map("vendor_id")
  openingBalance   Decimal  @default(0) @map("opening_balance") @db.Decimal(12, 2)
  currentBalance   Decimal  @default(0) @map("current_balance") @db.Decimal(12, 2)
  lastUpdated      DateTime @default(now()) @updatedAt @map("last_updated")

  vendor           Vendor   @relation(fields: [vendorId], references: [id])

  @@map("vendor_ledgers")
}

model VendorTransaction {
  id               Int      @id @default(autoincrement())
  vendorId         Int      @map("vendor_id")
  referenceType    String   @map("reference_type") @db.VarChar(50) // Bill, Payment, Return
  referenceId      Int?     @map("reference_id")
  transactionDate  DateTime @default(now()) @map("transaction_date")
  debit            Decimal  @default(0) @db.Decimal(12, 2)
  credit           Decimal  @default(0) @db.Decimal(12, 2)
  runningBalance   Decimal  @map("running_balance") @db.Decimal(12, 2)
  narration        String?  @db.Text
  createdAt        DateTime @default(now()) @map("created_at")

  vendor           Vendor   @relation(fields: [vendorId], references: [id])

  @@map("vendor_transactions")
}

model VendorBill {
  id             Int      @id @default(autoincrement())
  billNumber     String   @unique @map("bill_number")
  invoiceNumber  String?  @map("invoice_number") @db.VarChar(100)
  vendorId       Int      @map("vendor_id")
  poId           Int?     @map("po_id")
  grnId          Int?     @map("grn_id")
  billDate       DateTime @default(now()) @map("bill_date")
  dueDate        DateTime @map("due_date")
  
  subtotal       Decimal  @default(0) @db.Decimal(12, 2)
  taxAmount      Decimal  @default(0) @map("tax_amount") @db.Decimal(12, 2)
  tdsAmount      Decimal  @default(0) @map("tds_amount") @db.Decimal(12, 2)
  totalAmount    Decimal  @map("total_amount") @db.Decimal(12, 2)
  
  paidAmount     Decimal  @default(0) @map("paid_amount") @db.Decimal(12, 2)
  balanceAmount  Decimal  @map("balance_amount") @db.Decimal(12, 2)
  
  status         String   @default("Draft") @db.VarChar(50) // Draft, Matched, Exception, Approved, Paid
  approvalStatus String   @default("Pending") @map("approval_status") @db.VarChar(50)
  duplicateFlag  Boolean  @default(false) @map("duplicate_flag")
  exceptionNote  String?  @map("exception_note") @db.Text
  createdAt      DateTime @default(now()) @map("created_at")

  vendor         Vendor   @relation(fields: [vendorId], references: [id])
  po             PurchaseOrder? @relation(fields: [poId], references: [id])
  grn            GRN?     @relation(fields: [grnId], references: [id])
  payments       VendorPayment[]

  @@map("vendor_bills")
}

model VendorPayment {
  id             Int      @id @default(autoincrement())
  vendorId       Int      @map("vendor_id")
  billId         Int?     @map("bill_id")
  paymentDate    DateTime @default(now()) @map("payment_date")
  amount         Decimal  @db.Decimal(12, 2)
  paymentMode    String   @map("payment_mode") @db.VarChar(30)
  transactionRef String?  @map("transaction_ref") @db.VarChar(100)
  remarks        String?  @db.Text
  createdAt      DateTime @default(now()) @map("created_at")

  vendor         Vendor   @relation(fields: [vendorId], references: [id])
  bill           VendorBill? @relation(fields: [billId], references: [id])

  @@map("vendor_payments")
}

model PurchaseOrder {
  id            Int      @id @default(autoincrement())
  poNumber      String   @unique @map("po_number") // e.g. PO-2023-001
  vendorId      Int      @map("vendor_id")
  poDate        DateTime @default(now()) @map("po_date")
  expectedDate  DateTime? @map("expected_date")
  totalAmount   Decimal  @map("total_amount") @db.Decimal(12, 2)
  taxAmount     Decimal  @map("tax_amount") @db.Decimal(12, 2)
  status        String   @default("Draft") @db.VarChar(30)
  version       Int      @default(1)
  cancelledAt   DateTime? @map("cancelled_at")
  remarks       String?  @db.Text
  createdAt     DateTime @default(now()) @map("created_at")

  history       PurchaseOrderVersion[]

  vendor        Vendor   @relation(fields: [vendorId], references: [id])
  items         PurchaseOrderItem[]
  grns          GRN[]
  vendorBills   VendorBill[]

  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id          Int      @id @default(autoincrement())
  poId        Int      @map("po_id")
  productId   Int      @map("product_id")
  quantity    Int
  unitPrice   Decimal  @map("unit_price") @db.Decimal(10, 2)
  taxableValue Decimal @map("taxable_value") @db.Decimal(12, 2)
  cgst        Decimal  @default(0) @db.Decimal(10, 2)
  sgst        Decimal  @default(0) @db.Decimal(10, 2)
  igst        Decimal  @default(0) @db.Decimal(10, 2)
  taxPercent  Decimal  @map("tax_percent") @db.Decimal(5, 2)
  total       Decimal  @db.Decimal(12, 2)

  po          PurchaseOrder @relation(fields: [poId], references: [id], onDelete: Cascade)
  product     Product       @relation(fields: [productId], references: [id])

  @@map("purchase_order_items")
}

model PurchaseOrderVersion {
  id          Int      @id @default(autoincrement())
  poId        Int      @map("po_id")
  version     Int
  data        Json     // Full snapshot of the PO at this version
  changedBy   Int?     @map("changed_by")
  changeNote  String?  @map("change_note")
  createdAt   DateTime @default(now()) @map("created_at")

  po          PurchaseOrder @relation(fields: [poId], references: [id], onDelete: Cascade)

  @@map("purchase_order_versions")
}

model GRN {
  id           Int      @id @default(autoincrement())
  grnNumber    String   @unique @map("grn_number") // e.g. GRN-001
  poId         Int      @map("po_id")
  receivedDate DateTime @default(now()) @map("received_date")
  warehouse    String?  @db.VarChar(100)
  receivedBy   String?  @map("received_by") @db.VarChar(100)
  remarks      String?  @db.Text
  createdAt    DateTime @default(now()) @map("created_at")

  po           PurchaseOrder @relation(fields: [poId], references: [id])
  items        GRNItem[]
  bills        VendorBill[]

  @@map("grns")
}

model GRNItem {
  id           Int      @id @default(autoincrement())
  grnId        Int      @map("grn_id")
  productId    Int      @map("product_id")
  orderedQty   Int      @map("ordered_qty")
  receivedQty  Int      @map("received_qty")
  damagedQty   Int      @default(0) @map("damaged_qty")
  pendingQty   Int      @map("pending_qty")

  grn          GRN      @relation(fields: [grnId], references: [id], onDelete: Cascade)
  product      Product  @relation(fields: [productId], references: [id])

  @@map("grn_items")
}

model PurchaseRequest {
  id              Int      @id @default(autoincrement())
  productName     String   @map("product_name")
  sku             String
  requiredQty     Int      @map("required_qty")
  vendorSuggestion String? @map("vendor_suggestion")
  status          String   @default("Pending")
  createdAt       DateTime @default(now()) @map("created_at")

  @@map("purchase_requests")
}

model Department {
  id          Int        @id @default(autoincrement())
  name        String     @unique @db.VarChar(100)
  headId      Int?       @map("head_id")
  createdAt   DateTime   @default(now()) @map("created_at")

  employees   Employee[]
  jobs        JobPosting[]
  
  @@map("departments")
}

model Designation {
  id          Int        @id @default(autoincrement())
  title       String     @unique @db.VarChar(100)
  level       Int        @default(1)
  
  employees   Employee[]
  
  @@map("designations")
}

model Employee {
  id           Int      @id @default(autoincrement())
  empCode      String   @unique @map("emp_code") @default(uuid())
  name         String   @db.VarChar(100)
  email        String   @db.VarChar(100) @unique
  phone        String?  @db.VarChar(20)
  
  departmentId Int?     @map("department_id")
  designationId Int?    @map("designation_id")
  managerId    Int?     @map("manager_id")
  branchId     Int?     @map("branch_id")
  
  // Compliance & Tax
  panNumber    String?  @map("pan_number") @db.VarChar(20)
  uanNumber    String?  @map("uan_number") @db.VarChar(30)
  esiNumber    String?  @map("esi_number") @db.VarChar(30)
  bankDetails  Json?    @map("bank_details")
  
  skills       Json?
  experience   Int?     // In months
  status       String   @default("Active") @db.VarChar(30)
  
  salary       Decimal  @db.Decimal(12, 2)
  overtimeRate Decimal  @default(0) @map("overtime_rate") @db.Decimal(10, 2)
  
  joiningDate  DateTime @default(now()) @map("joining_date")
  createdAt    DateTime @default(now()) @map("created_at")

  department   Department? @relation(fields: [departmentId], references: [id])
  designation  Designation? @relation(fields: [designationId], references: [id])
  manager      Employee?   @relation("ManagerHierarchy", fields: [managerId], references: [id])
  subordinates Employee[]  @relation("ManagerHierarchy")

  attendances  Attendance[]
  payrolls     Payroll[]
  leaves       Leave[]
  reviews      PerformanceReview[] @relation("Reviewee")
  givenReviews PerformanceReview[] @relation("Reviewer")
  exitRequest  ExitRequest?
  expenses     ExpenseClaim[]
  assets       Asset[]
  salaryStructure SalaryStructure?

  @@map("employees")
}

model JobPosting {
  id           Int      @id @default(autoincrement())
  title        String   @db.VarChar(100)
  departmentId Int      @map("department_id")
  location     String   @db.VarChar(100)
  experience   String   @db.VarChar(50)
  status       String   @default("Open") @db.VarChar(30)
  createdAt    DateTime @default(now()) @map("created_at")
  
  department   Department @relation(fields: [departmentId], references: [id])
  candidates   Candidate[]
  
  @@map("job_postings")
}

model Candidate {
  id           Int      @id @default(autoincrement())
  jobId        Int      @map("job_id")
  name         String   @db.VarChar(100)
  email        String   @db.VarChar(100)
  resumeUrl    String?  @map("resume_url") @db.Text
  status       String   @default("Applied") @db.VarChar(50) // Applied, Interview, Offered, Rejected
  createdAt    DateTime @default(now()) @map("created_at")
  
  job          JobPosting @relation(fields: [jobId], references: [id])
  
  @@map("candidates")
}

model ExpenseClaim {
  id           Int      @id @default(autoincrement())
  employeeId   Int      @map("employee_id")
  title        String   @db.VarChar(200)
  amount       Decimal  @db.Decimal(12, 2)
  receiptUrl   String?  @map("receipt_url") @db.Text
  status       String   @default("Pending") @db.VarChar(50) // Pending, Approved, Rejected, Reimbursed
  createdAt    DateTime @default(now()) @map("created_at")
  
  employee     Employee @relation(fields: [employeeId], references: [id])
  
  @@map("expense_claims")
}

model Asset {
  id           Int      @id @default(autoincrement())
  assetCode    String   @unique @map("asset_code")
  name         String   @db.VarChar(100)
  type         String   @db.VarChar(50) // Laptop, Phone, Software
  assignedTo   Int?     @map("assigned_to")
  status       String   @default("Available") @db.VarChar(30) // Available, Assigned, Damaged
  assignedDate DateTime? @map("assigned_date")
  
  employee     Employee? @relation(fields: [assignedTo], references: [id])
  
  @@map("assets")
}

model Attendance {
  id         Int      @id @default(autoincrement())
  employeeId Int      @map("employee_id")
  date       DateTime @default(now()) @db.Date
  loginTime  DateTime? @map("login_time")
  logoutTime DateTime? @map("logout_time")
  workHours  Decimal? @map("work_hours") @db.Decimal(5, 2)
  status     String   @db.VarChar(20)

  employee   Employee @relation(fields: [employeeId], references: [id])

  @@map("attendance")
}

model Leave {
  id         Int      @id @default(autoincrement())
  employeeId Int      @map("employee_id")
  leaveType  String   @map("leave_type") @db.VarChar(50)
  startDate  DateTime @map("start_date") @db.Date
  endDate    DateTime @map("end_date") @db.Date
  reason     String?  @db.Text
  status     String   @default("Pending") @db.VarChar(30)
  appliedAt  DateTime @default(now()) @map("applied_at")

  employee   Employee @relation(fields: [employeeId], references: [id])

  @@map("leaves")
}

model PerformanceReview {
  id          Int      @id @default(autoincrement())
  employeeId  Int      @map("employee_id")
  reviewerId  Int      @map("reviewer_id")
  reviewMonth String   @map("review_month") @db.VarChar(20)
  reviewYear  Int      @map("review_year")
  rating      Int      
  comments    String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at")

  employee    Employee @relation("Reviewee", fields: [employeeId], references: [id])
  reviewer    Employee @relation("Reviewer", fields: [reviewerId], references: [id])

  @@map("performance_reviews")
}

model ExitRequest {
  id              Int      @id @default(autoincrement())
  employeeId      Int      @unique @map("employee_id")
  resignationDate DateTime @map("resignation_date") @db.Date
  lastWorkingDay  DateTime @map("last_working_day") @db.Date
  reason          String?  @db.Text
  status          String   @default("Pending") @db.VarChar(30)
  clearanceStatus Json?    @map("clearance_status")
  createdAt       DateTime @default(now()) @map("created_at")

  employee        Employee @relation(fields: [employeeId], references: [id])

  @@map("exit_requests")
}

// ... Replaced above

model Project {
  id               Int      @id @default(autoincrement())
  projectCode      String   @unique @map("project_code") // e.g. ZEN-001
  name             String   @db.VarChar(200)
  description      String?  @db.Text
  clientName       String?  @map("client_name") @db.VarChar(100)
  managerId        Int?     @map("manager_id")
  status           String   @default("Active") @db.VarChar(50)
  priority         String   @default("Medium") @db.VarChar(20)
  startDate        DateTime @default(now()) @map("start_date")
  endDate          DateTime? @map("end_date")
  completionPercent Int     @default(0) @map("completion_percent")
  createdAt        DateTime @default(now()) @map("created_at")

  tasks            Task[]
  sprints          Sprint[]

  @@map("projects")
}

model Sprint {
  id          Int      @id @default(autoincrement())
  projectId   Int      @map("project_id")
  name        String   @db.VarChar(100)
  startDate   DateTime @map("start_date")
  endDate     DateTime @map("end_date")
  status      String   @default("Planned") @db.VarChar(50)
  capacity    Int?     
  createdAt   DateTime @default(now()) @map("created_at")

  project     Project  @relation(fields: [projectId], references: [id])
  tasks       Task[]

  @@map("sprints")
}

model Task {
  id               Int      @id @default(autoincrement())
  taskCode         String   @unique @map("task_code") // e.g. TASK-001
  title            String   @db.VarChar(255)
  description      String?  @db.Text
  type             String   @default("Task") @db.VarChar(50) // Epic, Story, Task, Bug
  status           String   @default("Backlog") @db.VarChar(50)
  priority         String   @default("P3") @db.VarChar(20)
  
  projectId        Int?     @map("project_id")
  sprintId         Int?     @map("sprint_id")
  parentId         Int?     @map("parent_id")
  assigneeId       Int?     @map("assignee_id")
  reporterId       Int?     @map("reporter_id")

  storyPoints      Int?     @map("story_points")
  startDate        DateTime? @map("start_date")
  dueDate          DateTime? @map("due_date")
  completedAt      DateTime? @map("completed_at")
  estimatedHours   Decimal? @map("estimated_hours") @db.Decimal(10, 2)
  actualHours      Decimal? @map("actual_hours") @db.Decimal(10, 2) @default(0)
  estimatedCost    Decimal? @map("estimated_cost") @db.Decimal(12, 2) @default(0)
  actualCost       Decimal? @map("actual_cost") @db.Decimal(12, 2) @default(0)
  completionPercent Int     @default(0) @map("completion_percent")
  approvalStatus   String   @default("Pending") @map("approval_status") @db.VarChar(50)

  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  project          Project? @relation(fields: [projectId], references: [id])
  sprint           Sprint?  @relation(fields: [sprintId], references: [id])
  assignee         User?    @relation("TaskAssignee", fields: [assigneeId], references: [id])
  reporter         User?    @relation("TaskReporter", fields: [reporterId], references: [id])
  parent           Task?    @relation("TaskHierarchy", fields: [parentId], references: [id])
  subtasks         Task[]   @relation("TaskHierarchy")

  workLogs         WorkLog[]
  comments         TaskComment[]
  checklist        ChecklistItem[]
  logs             TaskLog[]

  @@map("tasks")
}

model WorkLog {
  id        Int      @id @default(autoincrement())
  taskId    Int      @map("task_id")
  userId    Int      @map("user_id")
  startTime DateTime @map("start_time")
  endTime   DateTime? @map("end_time")
  duration  Decimal? @db.Decimal(10, 2) // In hours
  note      String?  @db.Text

  task      Task     @relation(fields: [taskId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@map("work_logs")
}

model TaskComment {
  id        Int      @id @default(autoincrement())
  taskId    Int      @map("task_id")
  userId    Int      @map("user_id")
  content   String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  task      Task     @relation(fields: [taskId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@map("task_comments")
}

model ChecklistItem {
  id      Int     @id @default(autoincrement())
  taskId  Int     @map("task_id")
  content String  @db.VarChar(255)
  isDone  Boolean @default(false) @map("is_done")

  task    Task    @relation(fields: [taskId], references: [id])

  @@map("checklist_items")
}

model TaskLog {
  id        Int      @id @default(autoincrement())
  taskId    Int      @map("task_id")
  action    String   @db.VarChar(100)
  message   String   @db.Text
  userId    Int?     @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  task      Task     @relation(fields: [taskId], references: [id])
  user      User?    @relation(fields: [userId], references: [id])

  @@map("task_logs")
}



model TallySyncLog {
  id          Int      @id @default(autoincrement())
  module      String   // 'invoice' or 'purchase'
  referenceId String   @map("reference_id")
  status      String   // 'pending', 'success', 'failed'
  response    String?  @db.Text
  retryCount  Int      @default(0) @map("retry_count")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("tally_sync_logs")
}

model SalaryStructure {
  id           Int      @id @default(autoincrement())
  employeeId   Int      @unique @map("employee_id")
  basicSalary  Decimal  @map("basic_salary") @db.Decimal(12, 2)
  hra          Decimal  @default(0) @db.Decimal(12, 2)
  allowances   Decimal  @default(0) @db.Decimal(12, 2)
  pfEnabled    Boolean  @default(true) @map("pf_enabled")
  taxPercent   Decimal  @default(0) @map("tax_percent") @db.Decimal(5, 2)
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at")

  employee     Employee @relation(fields: [employeeId], references: [id])
  @@map("salary_structures")
}

model Payroll {
  id             Int      @id @default(autoincrement())
  employeeId     Int      @map("employee_id")
  month          String   @db.VarChar(20)
  year           Int
  
  basicSalary    Decimal  @map("basic_salary") @db.Decimal(12, 2)
  hra            Decimal  @default(0) @db.Decimal(12, 2)
  allowances     Decimal  @default(0) @db.Decimal(12, 2)
  bonus          Decimal  @default(0) @db.Decimal(12, 2)
  incentives     Decimal  @default(0) @db.Decimal(12, 2)
  grossSalary    Decimal  @map("gross_salary") @db.Decimal(12, 2)
  
  pfDeduction    Decimal  @default(0) @map("pf_deduction") @db.Decimal(12, 2)
  taxDeduction   Decimal  @default(0) @map("tax_deduction") @db.Decimal(12, 2)
  lopDays        Decimal  @default(0) @map("lop_days") @db.Decimal(5, 2)
  lopDeduction   Decimal  @default(0) @map("lop_deduction") @db.Decimal(12, 2)
  otherDeductions Decimal @default(0) @map("other_deductions") @db.Decimal(12, 2)
  totalDeductions Decimal @map("total_deductions") @db.Decimal(12, 2)
  
  netSalary      Decimal  @map("net_salary") @db.Decimal(12, 2)
  
  status         String   @default("Draft") @db.VarChar(30) // Draft, Processed, Paid
  paymentMode    String?  @map("payment_mode") @db.VarChar(50)
  paymentDate    DateTime? @map("payment_date")
  createdAt      DateTime @default(now()) @map("created_at")

  employee       Employee @relation(fields: [employeeId], references: [id])
  details        PayrollDetail[]

  @@unique([employeeId, month, year])
  @@map("payrolls")
}

model PayrollDetail {
  id            Int      @id @default(autoincrement())
  payrollId     Int      @map("payroll_id")
  componentName String   @map("component_name") @db.VarChar(100)
  type          String   @db.VarChar(20) // Earning, Deduction
  amount        Decimal  @db.Decimal(12, 2)

  payroll       Payroll  @relation(fields: [payrollId], references: [id])
  @@map("payroll_details")
}
